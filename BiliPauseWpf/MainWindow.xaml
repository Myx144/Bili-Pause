<Window x:Class="BiliPauseWpf.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="BiliPause" Height="240" Width="420"
        ResizeMode="CanMinimize" WindowStartupLocation="CenterScreen"
        WindowStyle="None" AllowsTransparency="True" Background="Transparent"
        StateChanged="Window_StateChanged">
    <WindowChrome.WindowChrome>
        <WindowChrome CaptionHeight="36" CornerRadius="8" GlassFrameThickness="0"
                      UseAeroCaptionButtons="False"/>
    </WindowChrome.WindowChrome>
    <Border CornerRadius="8" Margin="1">
        <Border.Background>
            <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                <GradientStop Color="#F3F3F9" Offset="0"/><GradientStop Color="#EBEBF3" Offset="1"/>
            </LinearGradientBrush>
        </Border.Background>
        <Border.Effect><DropShadowEffect BlurRadius="12" ShadowDepth="1" Opacity="0.25"/></Border.Effect>
        <Grid Margin="16,4,16,16">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/><RowDefinition Height="Auto"/><RowDefinition Height="Auto"/><RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <!-- Title bar row -->
            <Grid Grid.Row="0" Height="30" Margin="0,0,0,12">
                <TextBlock Text="BiliPause" FontSize="15" FontWeight="SemiBold"
                           Foreground="#1E1E2E" VerticalAlignment="Center"/>
                <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,-6,0,0">
                    <Button Content="─" Width="42" Height="30" Click="BtnMinimize" WindowChrome.IsHitTestVisibleInChrome="True"
                            Background="Transparent" Foreground="#666" BorderThickness="0"
                            FontSize="14" Cursor="Hand" Padding="0"/>
                    <Button Content="✕" Width="42" Height="30" Click="BtnClose" WindowChrome.IsHitTestVisibleInChrome="True"
                            Background="Transparent" Foreground="#666" BorderThickness="0"
                            FontSize="12" Cursor="Hand" Padding="0"/>
                </StackPanel>
            </Grid>

            <!-- Hint -->
            <TextBlock Grid.Row="1" FontSize="11.5" Foreground="#888" Margin="0,0,0,10"
                       Text="Mouse4 Pause/Play     Mouse5 Video back"/>

            <!-- Targets -->
            <Border Grid.Row="2" CornerRadius="6" Padding="10,8" Margin="0,0,0,8"
                    Background="#FDFDFF" BorderBrush="#E0E0EC" BorderThickness="1">
                <StackPanel>
                    <!-- Game -->
                    <Grid Margin="0,3" Height="26"><Grid.ColumnDefinitions><ColumnDefinition Width="44"/><ColumnDefinition Width="*"/><ColumnDefinition Width="60"/></Grid.ColumnDefinitions>
                        <TextBlock Text="Game" VerticalAlignment="Center" FontSize="12" Foreground="#555"/>
                        <Grid Grid.Column="1" Margin="4,0">
                            <TextBlock x:Name="phGame" Text="not selected" Foreground="#BBB"
                                       FontSize="11.5" VerticalAlignment="Center" IsHitTestVisible="False"/>
                            <TextBox x:Name="txtGame" IsReadOnly="True" Text=""
                                     BorderThickness="1" BorderBrush="#D4D4E4"
                                     Background="Transparent" FontSize="12"
                                     VerticalContentAlignment="Center" TextChanged="TxtGame_TextChanged"/>
                        </Grid>
                        <Button Grid.Column="2" Content="Select" Width="54" Height="22"
                                Click="BtnSelectGame" Background="#6366F1" Foreground="White"
                                BorderThickness="0" FontSize="11" Cursor="Hand"/>
                    </Grid>
                    <!-- Video -->
                    <Grid Margin="0,3" Height="26"><Grid.ColumnDefinitions><ColumnDefinition Width="44"/><ColumnDefinition Width="*"/><ColumnDefinition Width="60"/></Grid.ColumnDefinitions>
                        <TextBlock Text="Video" VerticalAlignment="Center" FontSize="12" Foreground="#555"/>
                        <Grid Grid.Column="1" Margin="4,0">
                            <TextBlock x:Name="phVideo" Text="not selected" Foreground="#BBB"
                                       FontSize="11.5" VerticalAlignment="Center" IsHitTestVisible="False"/>
                            <TextBox x:Name="txtVideo" IsReadOnly="True" Text=""
                                     BorderThickness="1" BorderBrush="#D4D4E4"
                                     Background="Transparent" FontSize="12"
                                     VerticalContentAlignment="Center" TextChanged="TxtVideo_TextChanged"/>
                        </Grid>
                        <Button Grid.Column="2" Content="Select" Width="54" Height="22"
                                Click="BtnSelectVideo" Background="#6366F1" Foreground="White"
                                BorderThickness="0" FontSize="11" Cursor="Hand"/>
                    </Grid>
                </StackPanel>
            </Border>

            <!-- Status -->
            <Border Grid.Row="3" CornerRadius="6" Padding="10,8"
                    Background="#FDFDFF" BorderBrush="#E0E0EC" BorderThickness="1">
                <DockPanel>
                    <Canvas x:Name="dotCanvas" Width="12" Height="12" Margin="0,0,8,0"
                            VerticalAlignment="Center"/>
                    <TextBlock x:Name="txtStatus" Text="Ready" VerticalAlignment="Center"
                               FontSize="12" Foreground="#555"/>
                    <Button x:Name="btnToggle" Content="Start" Width="60" Height="24"
                            Click="BtnToggle" HorizontalAlignment="Right"
                            Background="#22C55E" Foreground="White" BorderThickness="0"
                            FontSize="11" Cursor="Hand"/>
                </DockPanel>
            </Border>
        </Grid>
    </Border>
</Window>